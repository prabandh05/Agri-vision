{
  "expo": {
    "name": "AgriVision",
    "slug": "agrivision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrivision.mandya"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.agrivision.mandya"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ],
      "expo-asset"
    ],
    "assets": ["./assets/db/mandya_agri.db"]
  }
}
